# ==========================================
# ALFREDO HOME OS - CONFIGURAÇÕES GERAIS
# ==========================================

# 1. Inteligência Artificial (Nuvem)
# Chave da API gratuita da Groq (Obrigatório para a Etapa 4 - Conversas Abertas)
# Pegue sua chave em: https://console.groq.com/keys
GROQ_API_KEY=gsk_sua_chave_aqui

# 2. Segurança
# Token que os satélites (ESP32/Mock) usam para se comunicar com o servidor
ALFREDO_AUTH_TOKEN=secret-token-123

# 3. Clima (Weather Skill)
# Latitude e Longitude da sua casa (Opcional. Padrão: São Paulo)
# Pegue no Google Maps clicando com o botão direito na sua casa
WEATHER_LAT=-23.5505
WEATHER_LON=-46.6333

# 4. Voz (TTS)
# Voz padrão do Piper (opções: pt_BR-faber-medium, pt_BR-edresson-low, pt_PT-tugao-medium)
TTS_VOICE_MODEL=pt_BR-faber-medium
