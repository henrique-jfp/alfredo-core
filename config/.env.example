# ==========================================
# ALFREDO HOME OS - CONFIGURAÇÃO DE AMBIENTE
# ==========================================

# 1. Configurações do Servidor
SERVER_HOST=0.0.0.0
SERVER_PORT=10001
ENVIRONMENT=production # ou 'development' para o protótipo Celeron
LOG_LEVEL=INFO

# 2. Configurações da Família / Cliente
FAMILY_NAME=
ADMIN_NAME=
ADMIN_VOICE_PROFILE=default

# 1. Inteligência Artificial (Nuvem)
# Chave da API gratuita da Groq (Principal para conversas abertas)
# Pegue sua chave em: https://console.groq.com/keys
GROQ_API_KEY=

# Chave da API gratuita do Google Gemini (Fallback se a Groq falhar)
# Pegue sua chave em: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# 3. Integrações Básicas
# Usado para Open-Meteo
WEATHER_CITY=
WEATHER_LATITUDE=
WEATHER_LONGITUDE=

# 5. Segurança do Ecossistema
# Token Bearer esperado nos headers dos satélites (ESP32)
SATELLITE_AUTH_TOKEN=

# 6. Identificadores de Cômodos (Exemplo)
ROOM_ID_LIVING_ROOM=LIVING
ROOM_ID_MASTER_BEDROOM=MASTER
ROOM_ID_KITCHEN=KITCHEN

# 7. Modelos Locais (Vosk e Piper)
VOSK_MODEL_PATH=core/voice/stt/models/vosk-model-small-pt-0.3
PIPER_MODEL_PATH=core/voice/tts/models/pt_BR-faber-medium.onnx
